{
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [
    120
  ],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "[swift]": {
    "editor.defaultFormatter": "sswg.swift-lang",
    "editor.formatOnSave": true
  },
  "swift.buildArguments": [],
  "swift.disableAutoResolve": true,
  "files.exclude": {
    "**/*.xcodeproj": false,
    "**/DerivedData": true,
    "**/.DS_Store": true,
    "**/*.o": true
  },
  "files.associations": {
    "*.swift": "swift",
    "*.plist": "xml"
  },
  "search.exclude": {
    "**/DerivedData": true,
    "**/*.xcodeproj": true
  }
}
